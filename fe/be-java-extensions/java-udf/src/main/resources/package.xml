<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
    <id>jar-with-dependencies</id>
    <formats>
        <format>jar</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <!-- 1) 只把本模块编译产物打进去 -->
    <fileSets>
        <fileSet>
            <directory>${project.build.outputDirectory}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
    </fileSets>

    <!-- 2) 再解包运行时依赖，但显式排除 Parquet/Thrift 全族 -->
    <dependencySets>
        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <useTransitiveDependencies>true</useTransitiveDependencies>
            <unpack>true</unpack>
            <scope>runtime</scope>
            <excludes>
                <!-- 关键：把所有 Parquet/Thrift 排除掉 -->
                <exclude>org.apache.parquet:*</exclude>
                <exclude>org.apache.thrift:*</exclude>
                <!-- 防御：就算谁把 bundle 带进来，也排掉 -->
                <exclude>org.apache.parquet:parquet-hadoop-bundle</exclude>
            </excludes>
            <unpackOptions>
                <excludes>
                    <exclude>org/apache/parquet/**</exclude>
                    <exclude>org/apache/thrift/**</exclude>
                    <!-- 如果还有 hive/shaded 里塞进来的 thrift 路径，也一并过滤 -->
                    <exclude>shade/**/org/apache/thrift/**</exclude>
                    <exclude>**/Log4j2Plugins.dat</exclude>
                </excludes>
            </unpackOptions>
        </dependencySet>
    </dependencySets>
</assembly>
